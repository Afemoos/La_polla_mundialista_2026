rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email in [
        'afemos027@gmail.com',
        'afemos023@gmail.com',
        'daar.523@gmail.com'
      ];
    }

    match /system/radar_match {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() &&
        request.resource.data.homeTeam is string &&
        request.resource.data.awayTeam is string &&
        request.resource.data.homeFlag is string &&
        request.resource.data.awayFlag is string &&
        request.resource.data.stadium is string &&
        request.resource.data.date is string &&
        request.resource.data.probHome is int &&
        request.resource.data.probDraw is int &&
        request.resource.data.probAway is int &&
        request.resource.data.probHome + request.resource.data.probDraw + request.resource.data.probAway == 100;
    }

    match /system/colombia_match {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() &&
        request.resource.data.homeTeam is string &&
        request.resource.data.awayTeam is string &&
        request.resource.data.homeFlag is string &&
        request.resource.data.awayFlag is string &&
        request.resource.data.stadium is string &&
        request.resource.data.date is string &&
        request.resource.data.probHome is int &&
        request.resource.data.probDraw is int &&
        request.resource.data.probAway is int &&
        request.resource.data.probHome + request.resource.data.probDraw + request.resource.data.probAway == 100;
    }

    match /system/recent_results {
      allow read: if isAuthenticated();
      allow write: if false; // Solo escribe el bot via Admin SDK
    }

    match /system/api_status {
      allow read: if isAdmin();
      allow write: if false; // Solo escribe el bot via Admin SDK
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == uid &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.tokens == 0;
      allow update: if isAdmin() &&
        request.resource.data.tokens is int &&
        request.resource.data.tokens >= 0;
    }

    match /system/worldcup_path {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /predictions/{predictionId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.type == 'POLla_MUNDIALISTA' &&
        request.resource.data.matchDetails is string &&
        request.resource.data.prediction is string &&
        request.resource.data.status == 'PENDIENTE' &&
        (!('result' in request.resource.data) || request.resource.data.result == null);

      // AI-NOTE: Permitir al dueño actualizar predicciones Polla Mundialista (modificar marcador en ventana 48h)
      // o solicitar cancelación de predicciones PAGADAS
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.email == request.auth.token.email &&
        (!('result' in resource.data) || resource.data.result == null) && (
          // Cancelación: solo cambiar status de PAGADO a CANCELACION_SOLICITADA
          (resource.data.status == 'PAGADO' && request.resource.data.status == 'CANCELACION_SOLICITADA') ||
          // Modificación de predicción Polla Mundialista: solo cambiar prediction y lockedAt
          (resource.data.type == 'POLla_MUNDIALISTA' &&
           resource.data.status == 'PENDIENTE' &&
           request.resource.data.status == 'PENDIENTE' &&
           request.resource.data.prediction is string)
        )
      );
      
      allow delete: if isAdmin() || (
        isAuthenticated() &&
        resource.data.email == request.auth.token.email &&
        resource.data.status == 'PENDIENTE' &&
        (!('result' in resource.data) || resource.data.result == null)
      );
    }
  }
}
